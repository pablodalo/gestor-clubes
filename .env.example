# Base de datos (PostgreSQL). Obligatorio en producción.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# NextAuth. Obligatorios en producción para que /api/auth/* funcione.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generar-con-openssl-rand-base64-32"

# Opcional: en Vercel podés usar prefijo dbgc_ (ej. dbgc_DATABASE_URL) y el app los copia a las variables estándar.
# dbgc_DATABASE_URL=
# dbgc_NEXTAUTH_URL=
# dbgc_NEXTAUTH_SECRET=

# Opcional: si está definido, /api/health y /api/test-db exigen header x-internal-secret con este valor en producción.
# INTERNAL_API_SECRET=
