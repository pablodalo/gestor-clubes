# Database (PostgreSQL). En Vercel usar DATABASE_URL del add-on o Neon/Supabase.
DATABASE_URL="postgresql://user:password@localhost:5432/gestor_clubes?schema=public"

# NextAuth. Obligatorias en producción (Vercel). Generar secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-at-least-32-chars"

# Opcional: en producción, si está definido, /api/health y /api/test-db requieren header x-internal-secret con este valor.
# INTERNAL_API_SECRET="optional-secret-for-diagnostic-apis"

# Si en Vercel usás prefijo (ej. dbgc_), la app también lee: dbgc_DATABASE_URL, dbgc_NEXTAUTH_URL, dbgc_NEXTAUTH_SECRET
